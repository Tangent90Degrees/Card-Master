{
    "name": "card-master",
    "version": "1.0.0",
    "description": "Real-time multiplayer card sandbox (virtual tabletop).",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=20"
    },
    "workspaces": [
        "server",
        "client"
    ],
    "scripts": {
        "dev": "npm run dev --workspace server",
        "build": "npm run build --workspace client",
        "start": "npm run build && NODE_ENV=production npm run start --workspace server",
        "test": "npm run test --workspace server",
        "format": "prettier --write \"**/*.{js,jsx,css,json}\""
    },
    "devDependencies": {
        "prettier": "^3.8.3"
    }
}
